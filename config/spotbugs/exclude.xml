<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <Match>
        <Bug pattern="BC_UNCONFIRMED_CAST"/>
        <Class name="de.danoeh.antennapod.ui.screen.drawer.NavListAdapter"/>
    </Match>
    <Match>
        <Bug pattern="DLS_DEAD_LOCAL_STORE"/>
        <Class name="de.danoeh.antennapod.ui.statistics.StatisticsFragment"/>
    </Match>
    <Match>
        <Bug pattern="DM_DEFAULT_ENCODING"/>
        <Class name="de.danoeh.antennapod.parser.media.vorbis.VorbisCommentReader"/>
    </Match>
    <Match>
        <Bug pattern="EQ_CHECK_FOR_OPERAND_NOT_COMPATIBLE_WITH_THIS"/>
        <Class name="de.danoeh.antennapod.model.feed.FeedMedia"/>
    </Match>
    <Match>
        <Bug pattern="EQ_CHECK_FOR_OPERAND_NOT_COMPATIBLE_WITH_THIS"/>
        <Class name="de.danoeh.antennapod.model.playback.RemoteMedia"/>
    </Match>
    <Match>
        <Bug pattern="HSC_HUGE_SHARED_STRING_CONSTANT"/>
        <Class name="de.danoeh.antennapod.net.ssl.BackportCaCerts"/>
    </Match>
    <Match>
        <Bug pattern="ICAST_IDIV_CAST_TO_DOUBLE"/>
        <Class name="de.danoeh.antennapod.ui.echo.background.RotatingSquaresBackground"/>
    </Match>
    <Match>
        <Bug pattern="MS_CANNOT_BE_FINAL"/>
        <Class name="de.danoeh.antennapod.playback.service.PlaybackService"/>
    </Match>
    <Match>
        <Bug pattern="MS_MUTABLE_ARRAY"/>
        <Class name="de.danoeh.antennapod.ui.screen.drawer.NavDrawerFragment"/>
    </Match>
    <Match>
        <Bug pattern="MS_SHOULD_BE_FINAL"/>
        <Class name="de.danoeh.antennapod.net.common.UserAgentInterceptor"/>
    </Match>
    <Match>
        <Bug pattern="NP_NONNULL_PARAM_VIOLATION"/>
        <Class name="de.danoeh.antennapod.activity.MainActivity"/>
    </Match>
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH"/>
        <Class name="de.danoeh.antennapod.activity.MainActivity"/>
    </Match>
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH"/>
        <Class name="de.danoeh.antennapod.model.feed.FeedMedia"/>
    </Match>
    <Match>
        <Bug pattern="RV_RETURN_VALUE_IGNORED_BAD_PRACTICE"/>
        <Class name="de.danoeh.antennapod.PreferenceUpgrader"/>
    </Match>
    <Match>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
        <Class name="de.danoeh.antennapod.playback.service.PlaybackService"/>
    </Match>
    <Match>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
        <Class name="de.danoeh.antennapod.ui.home.sections.EpisodesSurpriseSection"/>
    </Match>
    <Match>
        <Bug pattern="BC_VACUOUS_INSTANCEOF"/>
        <Class name="de.danoeh.antennapod.ui.cleaner.PlainTextLinksConverter$LinkConvertingVisitor"/>
    </Match>

    <!-- TrimClient's nested types are Gson JSON DTOs: their fields are read/written by reflection
         during (de)serialization, so the unused/unread/unwritten-field detectors are false positives. -->
    <Match>
        <Bug pattern="URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD,UUF_UNUSED_PUBLIC_OR_PROTECTED_FIELD,UWF_UNWRITTEN_PUBLIC_OR_PROTECTED_FIELD"/>
        <Class name="~de\.danoeh\.antennapod\.playback\.service\.trim\.TrimClient.*"/>
    </Match>

    <Match><Package name="~.*\.databinding"/></Match>

    <Match><Bug pattern="DMI_RANDOM_USED_ONLY_ONCE"/></Match>
    <Match><Bug pattern="EI_EXPOSE_REP"/></Match>
    <Match><Bug pattern="EI_EXPOSE_REP2"/></Match>
    <Match><Bug pattern="HE_EQUALS_USE_HASHCODE"/></Match>
    <Match><Bug pattern="IS2_INCONSISTENT_SYNC"/></Match>
    <Match><Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/></Match>
    <Match><Bug pattern="OS_OPEN_STREAM"/></Match>
    <Match><Bug pattern="RV_RETURN_VALUE_IGNORED"/></Match>
    <Match><Bug pattern="SE_COMPARATOR_SHOULD_BE_SERIALIZABLE"/></Match>
    <Match><Bug pattern="SE_NO_SERIALVERSIONID"/></Match>
    <Match><Bug pattern="SE_TRANSIENT_FIELD_NOT_RESTORED"/></Match>
    <Match><Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/></Match>
    <Match><Bug pattern="VA_FORMAT_STRING_USES_NEWLINE"/></Match>
    <Match><Bug pattern="RV_RETURN_VALUE_IGNORED_NO_SIDE_EFFECT"/></Match>

    <!-- Pre-existing SpotBugs findings in TrimPlayer app code, surfaced once the CI XML + Checkstyle
         steps pass and SpotBugs actually runs. Each reviewed as a false-positive or an intentional
         pattern; excluded per-class in the same style as the carve-outs above. -->
    <Match>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE"/>
        <Class name="~de\.danoeh\.antennapod\.(QueuePrefetchManager|TrimQueueSubscriber|importflow\.ImportFlowController)"/>
    </Match>
    <Match>
        <!-- try-with-resources on InputStream: javac's synthesized finally null-check trips these. -->
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NULL_VALUE,NP_LOAD_OF_KNOWN_NULL_VALUE,UC_USELESS_CONDITION"/>
        <Class name="de.danoeh.antennapod.importflow.ImportFlowController"/>
    </Match>
    <Match>
        <Bug pattern="RV_RETURN_VALUE_IGNORED_BAD_PRACTICE"/>
        <Class name="de.danoeh.antennapod.migration.SpotifyMigrationActivity"/>
    </Match>
    <Match>
        <!-- Section.groupState() returns Boolean null as a deliberate tri-state (handled by callers). -->
        <Bug pattern="NP_BOOLEAN_RETURN_NULL,SIC_INNER_SHOULD_BE_STATIC"/>
        <Class name="~de\.danoeh\.antennapod\.portcast\.ConflictAdapter.*"/>
    </Match>
    <Match>
        <Bug pattern="FE_FLOATING_POINT_EQUALITY"/>
        <Class name="de.danoeh.antennapod.ui.screen.playback.audio.BoundaryEditor"/>
    </Match>
    <!-- Stats/telemetry data-holder classes: their public fields are written here and read in other
         modules (e.g. ui:statistics), but SpotBugs analyses each module in isolation and so reports
         the cross-module reads as unread. Same DTO carve-out already applied to TrimClient above. -->
    <Match>
        <Bug pattern="URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD,UUF_UNUSED_PUBLIC_OR_PROTECTED_FIELD,UWF_UNWRITTEN_PUBLIC_OR_PROTECTED_FIELD"/>
        <Class name="~de\.danoeh\.antennapod\.storage\.database\.DBReader\$.*"/>
    </Match>
    <Match>
        <Bug pattern="URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD,UUF_UNUSED_PUBLIC_OR_PROTECTED_FIELD,UWF_UNWRITTEN_PUBLIC_OR_PROTECTED_FIELD"/>
        <Class name="~de\.danoeh\.antennapod\.net\.common\.CommunityImpactClient.*"/>
    </Match>
    <Match>
        <Bug pattern="URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD,UUF_UNUSED_PUBLIC_OR_PROTECTED_FIELD,UWF_UNWRITTEN_PUBLIC_OR_PROTECTED_FIELD"/>
        <Class name="~de\.danoeh\.antennapod\.storage\.importexport\.(PodcastAddictImporter|PortcastImporter)\$.*"/>
    </Match>
    <!-- Missing switch default + dead store in the stats aggregation switches (exhaustive by design). -->
    <Match>
        <Bug pattern="SF_SWITCH_NO_DEFAULT,DLS_DEAD_LOCAL_STORE"/>
        <Class name="de.danoeh.antennapod.storage.database.DBReader"/>
    </Match>
    <!-- Best-effort temp-file cleanup: a failed delete()/mkdirs() is non-critical here. -->
    <Match>
        <Bug pattern="RV_RETURN_VALUE_IGNORED_BAD_PRACTICE"/>
        <Class name="~de\.danoeh\.antennapod\.(garmin\.GarminRenderer|storage\.importexport\.(DatabaseExporter|PodcastAddictImporter))"/>
    </Match>
    <!-- Custom view fields set via set() before invalidate(); non-null at draw. SpotBugs is
         conservative about the @Nullable annotations. -->
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH"/>
        <Class name="~de\.danoeh\.antennapod\.ui\.statistics\.CommunityImpactFragment.*"/>
    </Match>
</FindBugsFilter>
