<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="8dp"
    android:paddingVertical="10dp">

    <ImageView
        android:id="@+id/bookmarkCover"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="@null"
        android:importantForAccessibility="no"
        tools:src="@tools:sample/avatars" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/bookmarkEpisodeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Episode 214: The Moon Landing" />

        <TextView
            android:id="@+id/bookmarkDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:ellipsize="end"
            android:fontFeatureSettings="tnum"
            android:maxLines="2"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12.5sp"
            tools:ignore="UnusedAttribute"
            tools:text="12:34 · Great story about the moon landing" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/bookmarkEditButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/bookmark_edit_note"
        android:src="@drawable/ic_edit"
        app:tint="?attr/colorOnSurfaceVariant" />

    <ImageButton
        android:id="@+id/bookmarkDeleteButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/bookmark_delete"
        android:src="@drawable/ic_delete"
        app:tint="?attr/colorOnSurfaceVariant" />

</LinearLayout>
