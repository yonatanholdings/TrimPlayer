<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="20dp"
    android:paddingEnd="8dp"
    android:paddingVertical="8dp">

    <ImageView
        android:id="@+id/bookmarkIcon"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/bg_segment_icon"
        android:contentDescription="@null"
        android:padding="10dp"
        android:src="@drawable/ic_bookmark"
        android:backgroundTint="?attr/colorSurfaceVariant"
        app:tint="?attr/colorPrimary" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/bookmarkPosition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFeatureSettings="tnum"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15.5sp"
            android:textStyle="bold"
            tools:ignore="UnusedAttribute"
            tools:text="12:34" />

        <TextView
            android:id="@+id/bookmarkNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12.5sp"
            tools:text="Great story about the moon landing" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/bookmarkEditButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/bookmark_edit_note"
        android:src="@drawable/ic_edit"
        app:tint="?attr/colorOnSurfaceVariant" />

    <ImageButton
        android:id="@+id/bookmarkDeleteButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/bookmark_delete"
        android:src="@drawable/ic_delete"
        app:tint="?attr/colorOnSurfaceVariant" />

</LinearLayout>
