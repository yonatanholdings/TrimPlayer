<?xml version="1.0" encoding="utf-8"?>
<!-- One numbered step row (number + text, with an optional screenshot below),
     inflated per item by MigrationGuideActivity. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <TextView
            android:id="@+id/step_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="28dp"
            android:gravity="end"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/step_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:textAppearance="?attr/textAppearanceBodyMedium" />
    </LinearLayout>

    <!-- Raw (cropped) screenshot for this step, framed so it reads as an
         intentional capture. GONE when the step has no image. -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/step_image_card"
        style="@style/Widget.Material3.CardView.Outlined"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="42dp"
        android:layout_marginTop="10dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp">

        <ImageView
            android:id="@+id/step_image"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:maxHeight="420dp"
            android:scaleType="fitCenter" />
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
