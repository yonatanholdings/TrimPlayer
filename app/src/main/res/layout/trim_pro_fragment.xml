<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/trimProHeadline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trim_pro_screen_headline"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:layout_marginBottom="16dp" />

        <!-- Pro-active banner, shown when status == "pro" -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/trimProActiveCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/trimProActiveTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/trim_pro_status_active_title"
                        android:textAppearance="?attr/textAppearanceSubtitle1" />

                    <TextView
                        android:id="@+id/trimProSupporterBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:text="@string/trim_pro_badge_supporter"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:textStyle="bold"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:background="?attr/colorSecondaryContainer"
                        android:textColor="?attr/colorOnSecondaryContainer" />
                </LinearLayout>

                <TextView
                    android:id="@+id/trimProActiveSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBody2" />

                <TextView
                    android:id="@+id/trimProSupporterThanks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:text="@string/trim_pro_status_supporter_thanks"
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:textStyle="italic"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Supporter Digest card. Visible only when source == play_supporter. -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/trimProDigestCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/trim_digest_title"
                    android:textAppearance="?attr/textAppearanceSubtitle1" />

                <TextView
                    android:id="@+id/trimProDigestPeriod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceCaption"
                    android:layout_marginBottom="12dp" />

                <!-- Loading / empty / error states. Mutually exclusive with content. -->
                <TextView
                    android:id="@+id/trimProDigestMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBody2" />

                <!-- Content block (hidden until digest loads). -->
                <LinearLayout
                    android:id="@+id/trimProDigestContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/trim_digest_section_community"
                        android:textAppearance="?attr/textAppearanceOverline"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/trimProDigestCumulative"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceSubtitle2"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/trimProDigestTotalMinutes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBody1" />

                    <TextView
                        android:id="@+id/trimProDigestChange"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceCaption" />

                    <TextView
                        android:id="@+id/trimProDigestAvgListener"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBody2"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/trimProDigestYourStats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBody2" />

                    <TextView
                        android:id="@+id/trimProDigestSkipBreakdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:layout_marginTop="6dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/trimProDigestAccuracy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/trimProDigestCatalogPodcasts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:layout_marginTop="6dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/trimProDigestCatalogSegments"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:visibility="gone" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/trim_digest_top_podcasts"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:layout_marginTop="8dp" />

                    <LinearLayout
                        android:id="@+id/trimProDigestTopPodcasts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutline"
                        android:alpha="0.3"
                        android:layout_marginVertical="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/trim_digest_section_dev"
                        android:textAppearance="?attr/textAppearanceOverline" />

                    <TextView
                        android:id="@+id/trimProDigestFunding"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBody2" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/trim_digest_shipped"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:layout_marginTop="8dp" />

                    <LinearLayout
                        android:id="@+id/trimProDigestShipped"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/trim_digest_next"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:layout_marginTop="8dp" />

                    <LinearLayout
                        android:id="@+id/trimProDigestNext"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/trimProDigestNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBody2"
                        android:textStyle="italic"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Quota status, shown only for free users -->
        <TextView
            android:id="@+id/trimProQuotaLine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:textAppearance="?attr/textAppearanceBody2"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trim_pro_screen_features_title"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trim_pro_feature_unlimited"
            android:textAppearance="?attr/textAppearanceBody1"
            android:drawablePadding="12dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trim_pro_feature_priority"
            android:textAppearance="?attr/textAppearanceBody1"
            android:drawablePadding="12dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trim_pro_feature_early_access"
            android:textAppearance="?attr/textAppearanceBody1"
            android:drawablePadding="12dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trim_pro_feature_future_sync"
            android:textAppearance="?attr/textAppearanceBody1"
            android:drawablePadding="12dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/trimProPricingTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trim_pro_pricing_title"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/trimProPriceMonthly"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trim_pro_price_monthly"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/trimProPriceYearly"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trim_pro_price_yearly"
            android:layout_marginBottom="8dp" />

        <!-- Supporter purchase button + explainer. Hidden in v1 per
             pricing-plan decision 2026-05-19 (two-tier subscription only).
             Kept in the layout so flipping visibility=visible re-enables the
             tier without re-adding views. The fragment's render() also
             enforces this gone state defensively. -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/trimProPriceSupporter"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trim_pro_price_supporter"
            android:visibility="gone"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/trimProSupporterExplainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trim_pro_supporter_explainer"
            android:textAppearance="?attr/textAppearanceCaption"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />
    </LinearLayout>
</ScrollView>
