<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="20dp"
    android:paddingVertical="12dp">

    <ImageView
        android:id="@+id/segmentIcon"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/bg_segment_icon"
        android:contentDescription="@null"
        android:padding="10dp"
        android:src="@drawable/ic_content_cut"
        tools:backgroundTint="#FFDCA8"
        tools:tint="#C77800" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/segmentLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15.5sp"
            android:textStyle="bold"
            tools:text="Ad break" />

        <TextView
            android:id="@+id/segmentRange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:fontFeatureSettings="tnum"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12.5sp"
            tools:ignore="UnusedAttribute"
            tools:text="5:18 – 6:48 · 1m 30s" />
    </LinearLayout>

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_chevron_right"
        app:tint="?attr/colorOnSurfaceVariant" />
</LinearLayout>
