<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Summary line: "X of Y episodes will use Podcast Addict" -->
    <TextView
        android:id="@+id/conflictSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        style="@style/TextAppearance.Material3.BodyMedium" />

    <!-- Group-by toggle chips -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/groupByChips"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipByPodcast"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/podcast_addict_group_by_podcast"
            android:checked="true"
            style="@style/Widget.Material3.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipByDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/podcast_addict_group_by_date"
            style="@style/Widget.Material3.Chip.Filter" />

    </com.google.android.material.chip.ChipGroup>

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/conflictList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="240dp"
        android:maxHeight="420dp"
        android:clipToPadding="false" />

</LinearLayout>
