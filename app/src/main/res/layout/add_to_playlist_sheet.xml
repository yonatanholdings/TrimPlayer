<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom sheet: toggle an episode's membership across all playlists, with a
     "new playlist" shortcut on top. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="16dp">

    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:alpha="0.4"
        android:background="?android:attr/textColorSecondary" />

    <TextView
        android:id="@+id/sheet_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="4dp"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:text="@string/add_to_playlist_label" />

    <TextView
        android:id="@+id/sheet_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingBottom="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?android:attr/textColorSecondary"
        tools:text="Episode title" />

    <LinearLayout
        android:id="@+id/create_row"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_add"
            app:tint="?attr/colorAccent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_playlist_label"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorAccent" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/playlist_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="true" />

    <!-- First-playlist shortcut: shown only while no custom playlist exists.
         One tap creates the playlist AND files the episode into it. -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/suggestion_chips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="4dp"
        android:visibility="gone"
        app:chipSpacingVertical="4dp" />

</LinearLayout>
