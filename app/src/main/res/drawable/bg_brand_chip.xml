<!-- Neutral chip behind a full-color source-brand logo. White (light) / elevated
     grey (dark) with a hairline so white-edged marks don't bleed. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/brand_chip_bg" />
    <corners android:radius="10dp" />
    <stroke android:width="1dp" android:color="@color/brand_chip_stroke" />
</shape>
