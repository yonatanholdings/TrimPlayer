<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/feedbackScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <!-- ============== Your messages (inbox) ============== -->

            <TextView
                android:id="@+id/inboxTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/feedback_inbox_title"
                style="@style/TextAppearance.Material3.TitleMedium" />

            <ProgressBar
                android:id="@+id/inboxProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_gravity="center_horizontal"
                android:visibility="gone"
                style="?android:attr/progressBarStyleSmall"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/inboxEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/feedback_inbox_empty"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:textColor="?android:attr/textColorSecondary"
                style="@style/TextAppearance.Material3.BodyMedium" />

            <LinearLayout
                android:id="@+id/inboxThreadList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- ============== New message form ============== -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/report_bug_message"
                style="@style/TextAppearance.Material3.BodyMedium" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/categoryChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBug"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/feedback_category_bug"
                    android:checked="true"
                    style="@style/Widget.Material3.Chip.Filter" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFeature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/feedback_category_feature"
                    style="@style/Widget.Material3.Chip.Filter" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipOther"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/feedback_category_other"
                    style="@style/Widget.Material3.Chip.Filter" />

            </com.google.android.material.chip.ChipGroup>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/feedback_title_hint"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/feedbackTitleInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:maxLength="120"
                    android:maxLines="1" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/feedback_body_hint"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/feedbackBodyInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top|start"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="5"
                    android:maxLength="8000" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/attachDeviceSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/feedback_attach_device"
                android:checked="true" />

            <TextView
                android:id="@+id/devicePreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp"
                android:typeface="monospace"
                tools:text="TrimPlayer 1.2.3\nAndroid 14\nPixel 7" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/attachCrashSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/feedback_attach_crash"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/crashPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp"
                android:typeface="monospace"
                android:maxLines="3"
                android:ellipsize="end"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="java.lang.NullPointerException…" />

            <Button
                android:id="@+id/sendFeedbackButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/feedback_send"
                style="@style/Widget.Material3.Button" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
