<?xml version="1.0" encoding="utf-8"?>
<!-- Dev/admin message bubble: neutral surface, mirrored asymmetric corners
     (square at bottom-left) so the conversation pair looks like a back-and-
     forth even at a glance. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="?attr/colorSurfaceContainerHigh" />
    <corners
        android:topLeftRadius="18dp"
        android:topRightRadius="18dp"
        android:bottomLeftRadius="4dp"
        android:bottomRightRadius="18dp" />
</shape>
