<?xml version="1.0" encoding="utf-8"?>
<!-- Stateful background for the 3 category picker cards. Selected state
     lifts the surface color and shows a primary border; default state is a
     subtle outline. Padding is applied by the card content, not here. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="?attr/colorPrimaryContainer" />
            <corners android:radius="16dp" />
            <stroke android:width="2dp" android:color="?attr/colorPrimary" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="?attr/colorSurfaceContainer" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="?attr/colorOutlineVariant" />
        </shape>
    </item>
</selector>
