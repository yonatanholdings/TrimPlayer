<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Masthead strip -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:padding="8dp"
            android:paddingLeft="24dp" android:paddingRight="24dp"
            android:background="@android:color/white">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="● TRIM PLAYER STATISTICS"
                android:textSize="9sp" android:letterSpacing="0.15"
                android:textAllCaps="true" android:textColor="#7A6E60" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="HABITS &amp; SILENCES"
                android:textSize="9sp" android:letterSpacing="0.15"
                android:textAllCaps="true" android:textColor="#7A6E60" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="#1A15110D" />

        <!-- ─── 2×2 episode counters ─── -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingLeft="24dp" android:paddingRight="24dp"
            android:paddingTop="14dp" android:paddingBottom="14dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:paddingTop="12dp" android:paddingBottom="12dp">
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#15110D" android:layout_marginBottom="8dp" />
                    <TextView android:id="@+id/count_started"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="32sp" android:textColor="#15110D" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="STARTED" android:textSize="8sp" android:textAllCaps="true"
                        android:letterSpacing="0.15" android:textColor="#7A6E60" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:paddingLeft="16dp" android:paddingTop="12dp" android:paddingBottom="12dp">
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#1A15110D" android:layout_marginBottom="8dp" />
                    <TextView android:id="@+id/count_finished"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="32sp" android:textColor="#15110D" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="FINISHED" android:textSize="8sp" android:textAllCaps="true"
                        android:letterSpacing="0.15" android:textColor="#7A6E60" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:paddingTop="12dp" android:paddingBottom="12dp">
                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="#1A15110D" android:layout_marginBottom="8dp" />
                    <TextView android:id="@+id/count_inprogress"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="32sp" android:textColor="#15110D" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="IN PROGRESS" android:textSize="8sp" android:textAllCaps="true"
                        android:letterSpacing="0.15" android:textColor="#7A6E60" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:paddingLeft="16dp" android:paddingTop="12dp" android:paddingBottom="12dp">
                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="#1A15110D" android:layout_marginBottom="8dp" />
                    <TextView android:id="@+id/count_completed_pct"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="32sp" android:textColor="#15110D" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="COMPLETION" android:textSize="8sp" android:textAllCaps="true"
                        android:letterSpacing="0.15" android:textColor="#7A6E60" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- ─── §01 Hour-of-day bars ─── -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingLeft="24dp" android:paddingRight="24dp"
            android:paddingTop="8dp" android:paddingBottom="8dp" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="§ 01  WHEN YOU LISTEN"
                android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.15"
                android:textColor="#7A6E60" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="LOCAL TIME · WEEKDAY AVG"
                android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.15"
                android:textColor="#7A6E60" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:layout_marginLeft="24dp" android:layout_marginRight="24dp" android:background="#1A15110D" />

        <de.danoeh.antennapod.ui.statistics.editorial.HourBarsView
            android:id="@+id/hour_bars"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp" />

        <!-- ─── §02 Day-of-week ─── -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingLeft="24dp" android:paddingRight="24dp"
            android:paddingTop="8dp" android:paddingBottom="8dp" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="§ 02  DAY OF THE WEEK"
                android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.15"
                android:textColor="#7A6E60" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:layout_marginLeft="24dp" android:layout_marginRight="24dp" android:background="#1A15110D" />

        <de.danoeh.antennapod.ui.statistics.editorial.DayMultiplesView
            android:id="@+id/day_multiples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp" />

        <!-- ─── Thick rule ─── -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#15110D"
            android:layout_marginTop="8dp" android:layout_marginBottom="16dp" />

        <!-- ─── Time Saved ─── -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingLeft="24dp" android:paddingRight="24dp"
            android:paddingBottom="8dp" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TIME SAVED"
                android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.15"
                android:textColor="#7A6E60" />
            <TextView android:id="@+id/saved_pct_label"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.15"
                android:textColor="#B8442E" />
        </LinearLayout>

        <TextView android:id="@+id/saved_total"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="44sp" android:textColor="#15110D"
            android:paddingLeft="24dp" android:paddingRight="24dp" android:text="—" />

        <!-- Speed row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingLeft="24dp" android:paddingRight="24dp"
            android:paddingTop="12dp" android:paddingBottom="6dp" android:gravity="center_vertical">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Faster playback" android:textSize="14sp" android:textColor="#15110D" />
                <TextView android:id="@+id/saved_speed_detail"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="12sp" android:textColor="#7A6E60" />
            </LinearLayout>
            <TextView android:id="@+id/saved_speed_val"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="16sp" android:textColor="#15110D" android:layout_marginEnd="12dp" />
            <ProgressBar android:id="@+id/bar_speed"
                android:layout_width="80dp" android:layout_height="3dp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:max="1000" android:progressTint="#B8442E" android:progressBackgroundTint="#1A15110D" />
        </LinearLayout>

        <!-- Silence row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingLeft="24dp" android:paddingRight="24dp"
            android:paddingTop="6dp" android:paddingBottom="6dp" android:gravity="center_vertical">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Skip silence" android:textSize="14sp" android:textColor="#15110D" />
            </LinearLayout>
            <TextView android:id="@+id/saved_silence_val"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="16sp" android:textColor="#15110D" android:layout_marginEnd="12dp" />
            <ProgressBar android:id="@+id/bar_silence"
                android:layout_width="80dp" android:layout_height="3dp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:max="1000" android:progressTint="#A47436" android:progressBackgroundTint="#1A15110D" />
        </LinearLayout>

        <!-- Intros row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingLeft="24dp" android:paddingRight="24dp"
            android:paddingTop="6dp" android:paddingBottom="24dp" android:gravity="center_vertical">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Skip intros" android:textSize="14sp" android:textColor="#15110D" />
            </LinearLayout>
            <TextView android:id="@+id/saved_intros_val"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="16sp" android:textColor="#15110D" android:layout_marginEnd="12dp" />
            <ProgressBar android:id="@+id/bar_intros"
                android:layout_width="80dp" android:layout_height="3dp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:max="1000" android:progressTint="#15110D" android:progressBackgroundTint="#1A15110D" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
