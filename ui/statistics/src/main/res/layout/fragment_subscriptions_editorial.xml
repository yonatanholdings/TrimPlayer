<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- Masthead strip -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="8dp"
        android:paddingLeft="24dp" android:paddingRight="24dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="● TRIM PLAYER STATISTICS"
            android:textSize="9sp" android:letterSpacing="0.15"
            android:textAllCaps="true" android:textColor="#7A6E60" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="WHERE THE HOURS WENT"
            android:textSize="9sp" android:letterSpacing="0.15"
            android:textAllCaps="true" android:textColor="#7A6E60" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="0.5dp"
        android:background="#1A15110D" />

    <!-- Donut + top 3 side by side -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="24dp" android:paddingRight="24dp"
        android:paddingTop="16dp" android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
            <de.danoeh.antennapod.ui.statistics.editorial.DonutView
                android:id="@+id/donut_chart"
                android:layout_width="160dp"
                android:layout_height="160dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/donut_kicker"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="8sp" android:textAllCaps="true" android:letterSpacing="0.15"
                    android:textColor="#7A6E60" android:gravity="center" />
                <TextView android:id="@+id/donut_center"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="24sp" android:textColor="#15110D" android:gravity="center" />
                <TextView android:id="@+id/donut_caption"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="9sp" android:textColor="#7A6E60" android:gravity="center" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:paddingLeft="16dp">
            <TextView android:id="@+id/top_show_1"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="13sp" android:textColor="#15110D"
                android:paddingTop="4dp" android:paddingBottom="4dp" />
            <TextView android:id="@+id/top_show_2"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="13sp" android:textColor="#15110D"
                android:paddingTop="4dp" android:paddingBottom="4dp" />
            <TextView android:id="@+id/top_show_3"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="13sp" android:textColor="#15110D"
                android:paddingTop="4dp" android:paddingBottom="4dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Section label -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingLeft="24dp" android:paddingRight="24dp"
        android:paddingTop="8dp" android:paddingBottom="8dp" android:gravity="center_vertical">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="§ 01  ALL SUBSCRIPTIONS"
            android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.15"
            android:textColor="#7A6E60" />
        <TextView android:id="@+id/sort_label"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SORTED BY HOURS"
            android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.15"
            android:textColor="#7A6E60" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="0.5dp"
        android:background="#1A15110D" />

    <!-- Feed list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/subscriptions_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</LinearLayout>
