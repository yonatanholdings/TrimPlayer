<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/editorial_paper"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Hero: year-to-date listening -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Year to date"
                android:textSize="12sp"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:textColor="@color/editorial_ink_muted" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/hero_hours"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="64sp"
                    android:textColor="@color/editorial_ink"
                    android:includeFontPadding="false"
                    android:text="—" />

                <de.danoeh.antennapod.ui.statistics.editorial.SparklineView
                    android:id="@+id/hero_sparkline"
                    android:layout_width="96dp"
                    android:layout_height="40dp"
                    android:layout_marginBottom="10dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/hero_minutes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/editorial_ink_soft"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Thick rule -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="18dp"
            android:background="@color/editorial_ink" />

        <!-- Three-column key stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/hang_trimmed_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="30sp"
                    android:textColor="@color/editorial_ink"
                    android:includeFontPadding="false"
                    android:text="—" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trimmed"
                    android:textSize="12sp"
                    android:textColor="@color/editorial_ink_muted"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/hang_finished_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="30sp"
                    android:textColor="@color/editorial_ink"
                    android:includeFontPadding="false"
                    android:text="—" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Finished"
                    android:textSize="12sp"
                    android:textColor="@color/editorial_ink_muted"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/hang_streak_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="30sp"
                    android:textColor="@color/editorial_ink"
                    android:includeFontPadding="false"
                    android:text="—" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Day streak"
                    android:textSize="12sp"
                    android:textColor="@color/editorial_ink_muted"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Heatmap section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingBottom="10dp"
            android:gravity="bottom">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="When you listened"
                android:textSize="15sp"
                android:textColor="@color/editorial_ink" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last 26 weeks"
                android:textSize="12sp"
                android:textColor="@color/editorial_ink_muted" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginLeft="24dp"
            android:layout_marginRight="24dp"
            android:background="@color/editorial_rule_faint" />

        <de.danoeh.antennapod.ui.statistics.editorial.HeatmapView
            android:id="@+id/heatmap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="6dp" />

        <!-- Detail row — placeholder hint until a cell is tapped. -->
        <TextView
            android:id="@+id/heatmap_detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/editorial_ink_muted"
            android:textStyle="italic"
            android:layout_marginLeft="24dp"
            android:layout_marginRight="24dp"
            android:layout_marginBottom="8dp"
            android:text="Tap a day for details" />

        <!-- Episodes played on the tapped day. Hidden until a cell is tapped. -->
        <LinearLayout
            android:id="@+id/played_episodes_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/played_episodes_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Episodes played"
                android:textSize="15sp"
                android:textColor="@color/editorial_ink"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:paddingBottom="6dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginLeft="24dp"
                android:layout_marginRight="24dp"
                android:background="@color/editorial_rule_faint" />

            <LinearLayout
                android:id="@+id/played_episodes_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/played_episodes_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/editorial_ink_muted"
                android:textStyle="italic"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:visibility="gone"
                android:text="No episodes recorded for this day" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
