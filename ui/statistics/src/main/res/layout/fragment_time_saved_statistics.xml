<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Total all-time header -->
        <TextView
            android:id="@+id/total_saved_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="40sp"
            android:textColor="?android:attr/textColorPrimary"
            android:textStyle="bold"
            android:paddingTop="8dp"
            tools:text="3h 42m" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="14sp"
            android:text="@string/time_saved_total_label"
            android:paddingBottom="20dp" />

        <!-- Period cards row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:layout_margin="4dp">
                <TextView
                    android:id="@+id/period_today_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textStyle="bold"
                    tools:text="8m" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:text="@string/time_saved_today" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:layout_margin="4dp">
                <TextView
                    android:id="@+id/period_week_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textStyle="bold"
                    tools:text="38m" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:text="@string/time_saved_this_week" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:layout_margin="4dp">
                <TextView
                    android:id="@+id/period_month_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textStyle="bold"
                    tools:text="1h 52m" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:text="@string/time_saved_this_month" />
            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/dividerVertical"
            android:layout_marginBottom="16dp" />

        <!-- Breakdown by type -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:text="@string/time_saved_by_type"
            android:paddingBottom="12dp" />

        <!-- Intro row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="10dp">
            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="#4CAF50"
                android:layout_marginEnd="10dp" />
            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="@string/time_saved_type_intro" />
            <ProgressBar
                android:id="@+id/bar_intro"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:progressTint="#4CAF50"
                android:max="1000"
                tools:progress="400" />
            <TextView
                android:id="@+id/value_intro"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textSize="13sp"
                tools:text="12m 4s" />
        </LinearLayout>

        <!-- Outro row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="10dp">
            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="#FF9800"
                android:layout_marginEnd="10dp" />
            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="@string/time_saved_type_outro" />
            <ProgressBar
                android:id="@+id/bar_outro"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:progressTint="#FF9800"
                android:max="1000"
                tools:progress="200" />
            <TextView
                android:id="@+id/value_outro"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textSize="13sp"
                tools:text="5m" />
        </LinearLayout>

        <!-- Ads row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="10dp">
            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="#F44336"
                android:layout_marginEnd="10dp" />
            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="@string/time_saved_type_ads" />
            <ProgressBar
                android:id="@+id/bar_ads"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:progressTint="#F44336"
                android:max="1000"
                tools:progress="800" />
            <TextView
                android:id="@+id/value_ads"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textSize="13sp"
                tools:text="34m 20s" />
        </LinearLayout>

        <!-- Silence row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="10dp">
            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="#9E9E9E"
                android:layout_marginEnd="10dp" />
            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="@string/time_saved_type_silence" />
            <ProgressBar
                android:id="@+id/bar_silence"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:progressTint="#9E9E9E"
                android:max="1000"
                tools:progress="100" />
            <TextView
                android:id="@+id/value_silence"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textSize="13sp"
                tools:text="2m 10s" />
        </LinearLayout>

        <!-- Speed row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="4dp">
            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="#2196F3"
                android:layout_marginEnd="10dp" />
            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="@string/time_saved_type_speed" />
            <ProgressBar
                android:id="@+id/bar_speed"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:progressTint="#2196F3"
                android:max="1000"
                tools:progress="300" />
            <TextView
                android:id="@+id/value_speed"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textSize="13sp"
                tools:text="8m" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/dividerVertical"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Monthly history header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:text="@string/time_saved_monthly_history"
            android:paddingBottom="8dp" />

        <!-- Monthly list (populated dynamically) -->
        <LinearLayout
            android:id="@+id/monthly_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Empty state -->
        <TextView
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="14sp"
            android:paddingTop="32dp"
            android:paddingBottom="32dp"
            android:text="@string/time_saved_empty"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
