<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/editorial_paper">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Masthead strip -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:padding="8dp"
            android:paddingLeft="24dp" android:paddingRight="24dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="● TRIM PLAYER STATISTICS"
                android:textSize="9sp" android:letterSpacing="0.15"
                android:textAllCaps="true" android:textColor="@color/editorial_ink_muted" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SIX YEARS."
                android:textSize="9sp" android:letterSpacing="0.15"
                android:textAllCaps="true" android:textColor="@color/editorial_ink_muted" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/editorial_rule_faint" />

        <!-- Hero all-time stat -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingLeft="24dp" android:paddingRight="24dp"
            android:paddingTop="12dp" android:paddingBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ALL TIME, TOTAL"
                android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.15"
                android:textColor="@color/editorial_ink_muted" />
            <TextView android:id="@+id/all_time_hours"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="56sp" android:textColor="@color/editorial_ink" android:text="—" />
            <TextView android:id="@+id/all_time_days"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="14sp" android:textColor="@color/editorial_ink_soft" android:textStyle="italic" />
        </LinearLayout>

        <!-- Streamgraph -->
        <de.danoeh.antennapod.ui.statistics.editorial.StreamgraphView
            android:id="@+id/streamgraph"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <!-- Section §01 By year -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingLeft="24dp" android:paddingRight="24dp"
            android:paddingTop="8dp" android:paddingBottom="8dp" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="§ 01  BY YEAR"
                android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.15"
                android:textColor="@color/editorial_ink_muted" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="YEAR OVER YEAR"
                android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.15"
                android:textColor="@color/editorial_ink_muted" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/editorial_rule_faint" />

        <!-- Year rows injected by fragment -->
        <LinearLayout
            android:id="@+id/year_rows"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp" />

        <!-- ─── §02 Top shows for selected year ─── -->
        <LinearLayout
            android:id="@+id/year_drilldown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingBottom="24dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingLeft="24dp" android:paddingRight="24dp"
                android:paddingTop="8dp" android:paddingBottom="8dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="§ 02  TOP SHOWS"
                    android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.15"
                    android:textColor="@color/editorial_ink_muted" />
                <TextView android:id="@+id/year_drilldown_year"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="9sp" android:textAllCaps="true" android:letterSpacing="0.15"
                    android:textColor="@color/editorial_vermilion" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:layout_marginLeft="24dp" android:layout_marginRight="24dp"
                android:background="@color/editorial_rule_faint" />

            <LinearLayout
                android:id="@+id/year_drilldown_rows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="24dp" android:paddingRight="24dp"
                android:paddingTop="8dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
