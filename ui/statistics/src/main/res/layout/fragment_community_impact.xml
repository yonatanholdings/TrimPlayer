<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/editorial_paper"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- Empty / zero-pool state (shown only when there is no data at all). -->
        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="72dp"
            android:paddingBottom="72dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textColor="@color/editorial_ink"
                android:text="@string/community_impact_empty_headline" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textSize="14sp"
                android:textColor="@color/editorial_ink_muted"
                android:text="@string/community_impact_empty" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/content_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Hero: one display sentence, the two figures emphasized;
                 windowed via the chips below (caption shows the active window) ── -->
            <TextView
                android:id="@+id/hero_caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.10"
                android:textColor="@color/editorial_ink_muted"
                android:text="@string/community_impact_hero_caption" />

            <TextView
                android:id="@+id/hero_sentence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="10dp"
                android:includeFontPadding="false"
                android:lineSpacingExtra="3dp"
                android:textSize="22sp"
                android:textColor="@color/editorial_ink" />

            <!-- hero / body divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="26dp"
                android:layout_marginBottom="6dp"
                android:background="@color/editorial_rule_thick" />

            <!-- ── You vs the nation ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="30dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="17sp"
                    android:letterSpacing="0.01"
                    android:textColor="@color/editorial_ink"
                    android:text="@string/community_impact_compare_header" />

                <TextView
                    android:id="@+id/compare_window_caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/editorial_ink_muted" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="8dp"
                android:background="@color/editorial_rule_faint" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/window_chips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:singleLine="true"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_7d"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/community_impact_window_7d"
                    style="@style/Widget.MaterialComponents.Chip.Choice" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_30d"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/community_impact_window_30d"
                    style="@style/Widget.MaterialComponents.Chip.Choice" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_90d"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/community_impact_window_90d"
                    style="@style/Widget.MaterialComponents.Chip.Choice" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_1y"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/community_impact_window_1y"
                    style="@style/Widget.MaterialComponents.Chip.Choice" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/community_impact_window_all"
                    style="@style/Widget.MaterialComponents.Chip.Choice" />

            </com.google.android.material.chip.ChipGroup>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:textSize="12sp"
                android:textColor="@color/editorial_ink_muted"
                android:text="@string/community_impact_compare_legend" />

            <LinearLayout
                android:id="@+id/compare_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="6dp" />

            <!-- ── Where the time goes (collective breakdown; hidden when there's
                 no community data yet) ── -->
            <LinearLayout
                android:id="@+id/breakdown_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="32dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="17sp"
                        android:letterSpacing="0.01"
                        android:textColor="@color/editorial_ink"
                        android:text="@string/community_impact_breakdown_header" />

                    <TextView
                        android:id="@+id/breakdown_caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/editorial_ink_muted"
                        android:text="@string/community_impact_breakdown_caption" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/editorial_rule_faint" />

                <LinearLayout
                    android:id="@+id/breakdown_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

            <!-- ── Your contribution (a small coda, de-ranked from the section heads) ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="34dp"
                android:layout_marginBottom="16dp"
                android:background="@color/editorial_rule_thick" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.10"
                android:textColor="@color/editorial_ink_muted"
                android:text="@string/community_impact_your_contribution" />

            <TextView
                android:id="@+id/contribution_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:textSize="22sp"
                android:textColor="@color/editorial_ink" />

            <!-- Share CTA: lives here, after the proof — not before it. -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/share_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:textColor="@color/editorial_vermilion"
                android:text="@string/community_impact_share_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="12dp"
                app:strokeColor="@color/editorial_ink" />

            <!-- ── Footer ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="28dp"
                android:background="@color/editorial_rule_v_faint" />

            <TextView
                android:id="@+id/footer_updated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:textSize="12sp"
                android:textColor="@color/editorial_ink_muted" />

            <TextView
                android:id="@+id/footer_privacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:lineSpacingExtra="2dp"
                android:textSize="12sp"
                android:textColor="@color/editorial_ink_muted"
                android:text="@string/community_impact_privacy" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
