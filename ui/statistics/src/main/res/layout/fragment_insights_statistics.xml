<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Column header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="@string/insights_col_period"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:alpha="0.6" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="@string/insights_col_played"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:gravity="end"
                android:alpha="0.6" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="@string/insights_col_saved"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:gravity="end"
                android:alpha="0.6" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/insights_col_pct"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:gravity="end"
                android:alpha="0.6" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/dividerVertical"
            android:layout_marginBottom="4dp" />

        <!-- Rows container (filled programmatically) -->
        <LinearLayout
            android:id="@+id/rows_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/time_saved_empty"
            android:textSize="14sp"
            android:paddingTop="32dp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
